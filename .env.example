# Copy this file to .env.local and set your own key:
#   cp .env.example .env.local
#
# Create a key at https://console.anthropic.com (Settings -> API Keys).
# This repo ships with NO key. Each developer/student brings their own.
# The key is only ever read server-side and never reaches the browser.

ANTHROPIC_API_KEY=

# Model used to generate questions. Override if you like (e.g. claude-opus-4-8).
ANTHROPIC_MODEL=claude-sonnet-4-6
