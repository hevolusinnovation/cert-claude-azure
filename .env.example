# Copy this file to .env.local and set your own key:
#   cp .env.example .env.local
#
# Create a key at https://console.anthropic.com (Settings -> API Keys).
# This repo ships with NO key. Each developer/student brings their own.
# The key is only ever read server-side and never reaches the browser.

ANTHROPIC_API_KEY=

# Model used to generate questions. Override if you like (e.g. claude-opus-4-8).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Max time (ms) to wait for a single block-generation call before it times out.
# A long wait then fails with a clear, retryable error instead of hanging forever.
# Optional — defaults to 120000 (120s).
ANTHROPIC_TIMEOUT_MS=120000

# --- Database (Postgres) ---
# Connection string for the Postgres that stores users, exam sessions, the
# generated questions, and score history. docker-compose provides one for you;
# for `make dev` against the compose DB, the default below works.
DATABASE_URL=postgres://cca:cca@localhost:5432/cca

# --- Auth ---
# Secret used to sign the session cookie. Set a long random value.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=
